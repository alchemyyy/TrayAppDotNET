@startuml display_management_activity
!include dark-theme.puml
title Display management activity - acquisition, value reads/writes, manual sliders, and curve mode

start

partition "App startup" {
  :App.OnStartup loads AppSettings;
  :Create MonitorService(new DisplayService(), settings);
  note right $TINT_BLUE
    Settings sources read at startup:
    - EnvironmentalBrightnessCurveEnabled
    - EnvironmentalNightLightCurveEnabled
    - EnvironmentalOffsetMode
    - ApplyBrightnessOnStartup
    - LastMasterBrightness
    - DDC timing / validation settings
  end note
}

partition "MonitorService.Refresh - acquisition" {
  :TryGetMonitors();
  note right
    DisplayService.TryGetMonitors reads:
    - EnumDisplayMonitors HMONITOR/HDC
    - MONITORINFOEX adapter name
    - EnumDisplayDevices device ID
    - registry EDID block
    - CCD display number map
  end note

  :Compute runtime ID, EDIDKey, port fallback key;
  :RegisterKnownDisplays in displays.json;
  :Phase A removes or parks missing rows;

  if (Recent topology event within 1500 ms?) then (yes)
    :Delay remaining settle window;
    :Drop this Phase B if a newer Refresh generation exists;
  else (no)
    :Start Phase B immediately;
  endif
  :Increment Refresh generation for this Phase B;

  note right $TINT_AMBER
    Cold start does not intentionally wait 1500 ms.
    Hot-plug / wake paths do wait so fresh panels
    can settle before the first VCP read.
  end note

  while (Each enumerated DDCMonitor) is (next)
    :Match existing MonitorInfo by EDIDKey,\nthen ID, then port-form rescue;

    if (Existing DDC entry?) then (yes)
      :Refresh DDC handle fields;
      :await TryReadBrightnessWithRetryAsync\n(resolved brightness VCP; Task.Run retry loop);
      :Abort Phase B if Refresh generation is stale;
      if (read ok?) then (yes)
        :Keep row supported;\nclear LastDDCError;
      else (no)
        :Set SliderState = Failed;\nremove MonitorEntry;\ndrop queued write;
      endif
    elseif (Existing row without DDC entry?) then (promote)
      :await TryReadBrightnessWithRetryAsync\n(resolved brightness VCP; Task.Run retry loop);
      :Abort Phase B if Refresh generation is stale;
      if (read ok?) then (yes)
        :Create MonitorEntry;
        if (row already has explicit user/profile value?) then (yes)
          :Preserve manual slider baseline;
        else (no)
          if (Brightness curve query says engaged?) then (yes)
            :Preserve curve-owned slider baseline;
          else (no)
            :SyncBrightnessFromHardware(read percent)\nunder hardware-write suspension;
          endif
        endif
        :SliderState = OnHardwareRecovered(curve flag,\ndisabled-period flag);
        :Mark row acquired;
      else (no)
        :Keep row failed / read-degraded candidate;
      endif
    else (new row)
      :await TryReadBrightnessWithRetryAsync\n(resolved brightness VCP; Task.Run retry loop);
      :Abort Phase B if Refresh generation is stale;
      if (read ok?) then (supported)
        :seededBrightness = read percent;
        :new MonitorInfo(SliderState = InitialHardwareFunctionalSliderState);
        :InitializeBrightnessFromHardware(seededBrightness);
        :Create MonitorEntry;
        :Mark row acquired;
      else (unsupported)
        :new MonitorInfo(Brightness = 0,\nSliderState = Failed,\nLastDDCError = read error);
      endif
      :Subscribe MonitorService.OnMonitorPropertyChanged;
      :Monitors.Add(info);
    endif
  endwhile (done)

  :ResortMonitors;
  :Apply min/max bounds and per-monitor norm curves\nas metadata only;
  :Record WasEverDDCCapable;
  :Project WasEverDDCCapable onto MonitorInfo;
  :MonitorsAcquired(acquired rows);
  :MonitorsRefreshed event;

  note right $TINT_GREEN
    Retry waits no longer block the dispatcher:
    Phase B mutates rows on the UI thread, but each retrying
    DDC read runs through TryReadBrightnessWithRetryAsync.
    The generation guard prevents stale async reads from
    applying values after a newer topology refresh.

    Acquisition is read-only. MonitorsAcquired is the only
    post-acquisition hook that may write manual slider values,
    scaled by the row's last known VCP max, and only for newly
    acquired rows with explicit user/profile slider state.
    Curve rows write through the curve evaluator.
  end note
}

partition "BrightnessFlyout enrollment" {
  :BrightnessFlyout constructor binds Monitors directly;
  :Seed MasterMonitor.Brightness from LastMasterBrightness;
  :Seed curve backing fields directly from AppSettings;
  :Apply selected profile structure;

  if (brightness curve persisted on?) then (yes)
    :Skip profile hardware apply;
    :SuspendHardwareWrites;
    :ApplyCurrentProfile(includeBrightness: true)\nto restore slider intent only;
  else (no)
    if (ApplyBrightnessOnStartup?) then (yes)
      :ApplyCurrentProfile(includeBrightness: true);
    else (no)
      :Keep slider values from current DDC reads;
    endif
  endif

  :Compute master from connected\nhardware-functional individuals\nusing MasterSliderMode;
  :CaptureOffsetsFromMaster();
  note right $TINT_GREEN
    Offset writes happen here, for newly attached rows only,
    master drag start, sync commands, and individual re-engage.
    EnvironmentalCurveService should only read Offset;
    it should never write Offset or LastUserBrightness.
  end note

  :Create EnvironmentalCurveService;
  :Wire MonitorService queries\n(IsBrightnessCurveEnabledQuery,\nIsInDisabledPeriodQuery);

  if (any curve persisted on?) then (yes)
    :OnCurveToggleStateChanged();
    :Engage row SliderStates;
    :CaptureOffsetsFromMaster again;
    :Evaluate immediately;
  endif
}

partition "CollectionChanged attach path" {
  if (Monitors.Add fires after flyout exists?) then (yes)
    :AttachMonitor(m);
    :Add to Master.Dependents and AllItems;
    :Subscribe BrightnessFlyout.OnMonitorPropertyChanged;
    :Set _suppressPropagation = true;

    if (brightness curve on?) then (yes)
      :SuspendHardwareWrites;
      :ApplyCurrentProfile([m], includeBrightness: true);
      note right $TINT_GREEN
        This restores saved manual slider intent for a late monitor
        without pushing that manual value to DDC.
        The brightness curve remains the only hardware writer.
      end note
    elseif (ApplyBrightnessOnStartup?) then (yes)
      :ApplyCurrentProfile([m], includeBrightness: true);
      note right
        Late monitor receives the selected profile value
        through the same event-driven attach path.
      end note
    endif

    :InitializeOffsetFromMaster(m)\nfor this new row only;
    :UpdateMasterFromEnabledIndividuals();
    :Clear _suppressPropagation;
  endif

  note right $TINT_GREEN
    Topology changes enroll only the newly affected row.
    Existing monitors' Offset and LastUserBrightness are not
    recaptured on attach/detach, so staggered acquisition cannot
    retarget already-attached monitors' curve/manual baselines.
  end note
}

partition "Initial async enrollment rebaseline" {
  if (Flyout was constructed with Monitors.Count == 0\nand first MonitorsRefreshed arrives?) then (yes)
    :UpdateMasterFromEnabledIndividuals()\n(configured tracking mode);
    :CaptureOffsetsFromMaster();
    note right $TINT_GREEN
      Startup-only rebaseline.
      Runs before EnvironmentalCurveService handles the same
      MonitorsRefreshed event, so absolute curve targets consume
      offsets based on the final startup monitor set instead of
      the rolling/persisted master used during per-row attach.

      Does not run for later topology changes.
    end note
  endif
}

partition "Curve evaluator" {
  :Drivers: periodic timer,\nMonitorsRefreshed,\nprofile switch,\nsettings RequestEvaluation throttle,\npreview ApplyAt(t);
  :Resolve stored profile curve;
  :Resolve live sun-shifted curve cache;
  :Read current day fraction;
  :Read disabled period from stored curve;
  :Set IsInCurveDisabledPeriod mirror;

  if (brightness curve enabled?) then (yes)
    :HarmonizeBrightnessCurveStates();
  else (no)
    :DisengageBrightnessCurveStates();
  endif

  if (sleep just entered?) then (yes)
    :For CurveSleeping rows,\nEnqueueDirectBrightness(row.Brightness);
  endif

  if (brightness curve enabled?) then (yes)
    if (absolute mode?) then (yes)
      :sample = curve.Brightness(t);
      :master target = sample;
      :row target = sample + row.Offset;
    else (offset mode)
      :offsetPercent = (curve.BrightnessOffset(t) - 50) * 2;
      :master target = master.LastUserBrightness + offsetPercent;
      :row target = row.LastUserBrightness + offsetPercent;
    endif

    :Set CurveTargetBrightness on curve-driven rows;

    while (Each physical monitor) is (next)
      if (SliderState == CurveActive and not IsDragging?) then (yes)
        :EnqueueDirectBrightness(row, target);
      else (no)
        :No brightness hardware write;
      endif
    endwhile (done)
  endif

  note right $TINT_GREEN
    Intentional design boundary:
    Curve writes update:
    - CurveTargetBrightness for indicator/value label
    - hardware through EnqueueDirectBrightness

    Curve writes do NOT update:
    - MonitorInfo.Brightness
    - LastUserBrightness
    - Offset
    - profile MonitorState.Brightness
  end note
}

partition "Manual slider / wheel / hotkey path" {
  :User touches slider, wheel, tray scroll, or hotkey;

  if (absolute curve active and not disabled period?) then (yes)
    if (master row?) then (yes)
      :Turn brightness curve off;
      :ResyncBrightnessHardwareToSliders();
    elseif (individual row?) then (yes)
      :SliderState = OnUserRelease();\nCurveReleased survives ticks;
    endif
  else (offset mode or disabled period or curve off)
    :Keep curve flag as-is;
  endif

  if (master adjustment?) then (yes)
    :CaptureOffsetsFromMaster before value changes;
  endif

  :Slider.Value two-way binding writes MonitorInfo.Brightness;
  note right
    Brightness setter:
    - writes Brightness
    - writes LastUserBrightness
    - writes VirtualBrightness
    - raises PropertyChanged on rounded transitions
  end note

  :MonitorService.OnMonitorPropertyChanged;
  if (SuspendHardwareWrites active?) then (yes)
    :Return without OnUserRelease or DDC write;
  else (no)
    :Individual CurveActive/CurveSleeping -> CurveReleased;
    :EnqueueDirectBrightness(row, RoundedBrightness);
  endif

  :BrightnessFlyout.OnMonitorPropertyChanged;
  if (propagation allowed?) then (yes)
    if (master moved?) then (yes)
      :ApplyMasterToEnabledMonitors\n(master + stored Offset);
    else (individual moved)
    :UpdateMasterFromEnabledIndividuals()\n(configured tracking mode);
    endif
  endif

  if (brightness curve enabled and offset mode\nand not disabled period?) then (yes)
    :RequestEvaluation throttled by BrightnessUpdateRateMs;
  endif
}

partition "DDC write/read-back" {
  :EnqueueDirectBrightness(monitor, percent);
  :Apply per-monitor norm curve;
  :Clamp to [0,100] and min/max override;
  if (same as LastEnqueuedPercentage?) then (yes)
    :Skip duplicate write;
  else (no)
    :AsyncThrottler per monitor key\nlatest pending wins;
    :DoBrightnessWriteAsync();
    :WithDDCLockAsync per monitor DeviceID;
    :DisplayService.TrySetVCPFeature;
    if (write ok?) then (yes)
      :Stamp KnownDisplay.LastBusBrightness;
      :VerifyAppliedAsync read-back if no replacement queued;
    else (no)
      :Retry / demote to Failed if exhausted;
    endif
  endif

  note right $TINT_AMBER
    Boundary kept by design for now:
    writes are serialized per monitor, not by a global app arbiter.
    The OS / controller stack may already queue cross-monitor DDC
    commands. Acquisition Phase B still awaits reads sequentially
    in monitor order, with retry waits off the dispatcher.
  end note
}

partition "Topology event / recovery" {
  :DisplayEventManager receives WM_DEVICECHANGE,\nDisplaySettingsChanged, resume, unlock;
  :250 ms debounce;
  :App.OnDisplayTopologyChanged;
  :NotifyTopologyEvent();
  :Refresh();
  :Async Phase B eventually completes;
  :MonitorsAcquired(acquired rows);
  :MonitorsRefreshed event;
  :EnvironmentalCurveService.Evaluate;
  note right $TINT_GREEN
    Topology no longer replays slider state immediately
    after Refresh(), because Phase B may still be inside
    the settle window and cached handles may be stale.
  end note

  :DDCRecoveryService signals one global DDC fallback worker\nwhen Failed/read-degraded candidates exist;
  :Worker re-enters Refresh acquisition every 2 seconds\nuntil the candidate set clears;
  :PromoteRecovered / refresh promotion;
  :MonitorsAcquired(acquired rows);
  :MonitorsRefreshed;
}

partition "Audit findings / boundaries" {
  :1. Partial topology curve startup;
  note right $TINT_GREEN
    Fixed: attach/detach no longer recaptures offsets for
    surviving rows. A monitor that arrives later initializes only
    its own Offset, so topology changes do not retarget existing
    monitors' curve/manual baselines.
  end note

  :2. Physical brightness recovery curve gate;
  note right $TINT_GREEN
    Fixed: MonitorService now queries IsBrightnessCurveEnabledQuery.
    Night-light curve state no longer gates brightness recovery,
    brightness hardware sync, or brightness row promotion.
  end note

  :3. Night-light provider parity is intentional;
  note right $TINT_GREEN
    BrightnessFlyout.OnAppSettingsChanged copies provider strength
    into NightLightMonitor.Brightness by design.
    Windows can change night-light externally, so the app should
    reflect the provider's current value and use that as the
    visible baseline.
  end note

  :4. UI-thread DDC read retry;
  note right $TINT_GREEN
    Fixed for Refresh Phase B: retrying reads are wrapped in
    TryReadBrightnessWithRetryAsync and stale generations abort
    before row mutation. DDC fallback acquisition runs off-thread.
  end note

  :5. Startup manual vs curve ownership;
  note right $TINT_GREEN
    Curve-on startup restores saved manual slider intent under
    SuspendHardwareWrites, then curve evaluation writes hardware
    directly. Curve evaluation intentionally does not update
    Brightness, LastUserBrightness, Offset, or profile values.
    MonitorService suppresses automatic slider replays while
    the persisted brightness curve flag is on and the row has
    not been explicitly released, disabled, or parked by the
    disabled-period window.
  end note
}

stop
@enduml
