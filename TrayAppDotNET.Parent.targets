<Project>
  <PropertyGroup Condition="'$(TrayAppDotNETUseRootOutput)' != 'false'">
    <TrayAppDotNETOutputRoot Condition="'$(TrayAppDotNETOutputRoot)' == ''">$(TrayAppDotNETRoot)bin\</TrayAppDotNETOutputRoot>
    <OutDir>$(TrayAppDotNETOutputRoot)$(Configuration)\</OutDir>
    <OutputPath>$(OutDir)</OutputPath>
    <GenerateProjectSpecificOutputFolder>false</GenerateProjectSpecificOutputFolder>
    <UseCommonOutputDirectory>true</UseCommonOutputDirectory>
    <CopyRetryCount>20</CopyRetryCount>
    <CopyRetryDelayMilliseconds>250</CopyRetryDelayMilliseconds>
    <OverwriteReadOnlyFiles>true</OverwriteReadOnlyFiles>
    <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
    <NativeOutputPath Condition="'$(RuntimeIdentifier)' != '' and '$(NativeOutputPath)' == ''">$(IntermediateOutputPath)native-aot\</NativeOutputPath>
  </PropertyGroup>
</Project>
